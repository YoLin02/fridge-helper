.hero-row {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.4;
}

.hero-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}
