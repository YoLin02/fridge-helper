.hero-row {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.4;
}

.hero-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.home-recipe-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.home-recipe-item {
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f9fbfb;
}

.home-recipe-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.home-recipe-name,
.home-recipe-kcal {
  font-size: 30rpx;
  font-weight: 600;
}

.home-recipe-meta,
.home-recipe-reason {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
}

.plan-preview-title {
  font-size: 30rpx;
  font-weight: 600;
}

.plan-preview-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
}
