<view class="page-shell">
  <view class="page-header">
    <view>
      <view class="page-title">{{foodName}}</view>
      <view class="page-subtitle">按批次管理库存，列表页只显示聚合信息。</view>
    </view>
  </view>

  <section-card title="库存概览" subtitle="符合 AGENTS.md 的批次管理约束">
    <view class="overview-row">
      <view>
        <view class="overview-value">{{totalQuantity}}</view>
        <view class="overview-label">总库存</view>
      </view>
      <expire-tag text="{{nearestExpireText}}" state="{{nearestExpireState}}" />
    </view>
  </section-card>

  <section-card class="section-spacer" title="批次列表" subtitle="M2 收尾后可直接在详情页操作批次">
    <view class="batch-list">
      <block wx:for="{{batches}}" wx:key="id">
        <view class="batch-item">
          <view class="batch-top">
            <view class="batch-quantity">{{item.quantityText}}</view>
            <expire-tag text="{{item.expireText}}" state="{{item.expireState}}" />
          </view>
          <view class="batch-meta">入库日期：{{item.purchaseDate}}</view>
          <view class="batch-meta">到期日期：{{item.expireDate}}</view>
          <view class="batch-meta">存放位置：{{item.storageText}}</view>
          <view class="batch-actions">
            <view class="ghost-button small-button" data-id="{{item.id}}" bindtap="handleEdit">编辑</view>
            <view class="ghost-button small-button" data-id="{{item.id}}" bindtap="handleConsume">消耗</view>
            <view class="ghost-button small-button" data-id="{{item.id}}" bindtap="handleDiscard">丢弃</view>
          </view>
        </view>
      </block>
    </view>
  </section-card>
</view>
