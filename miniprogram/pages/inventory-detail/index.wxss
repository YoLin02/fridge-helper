.overview-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.overview-value {
  font-size: 52rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.overview-label {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.batch-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.batch-item {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f9fbfb;
}

.batch-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.batch-quantity {
  font-size: 32rpx;
  font-weight: 600;
}

.batch-meta {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.batch-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
  flex-wrap: wrap;
}

.small-button {
  height: 64rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}
