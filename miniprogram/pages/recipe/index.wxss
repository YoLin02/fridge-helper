.loading-copy {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.recipe-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.recipe-item {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f9fbfb;
}

.recipe-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.recipe-name,
.recipe-kcal {
  font-size: 32rpx;
  font-weight: 600;
}

.recipe-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.tag-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.tag-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--color-primary-soft);
  color: var(--color-primary);
  font-size: 22rpx;
}
