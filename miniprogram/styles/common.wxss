page {
  min-height: 100%;
  background:
    radial-gradient(circle at top, rgba(80, 227, 194, 0.12), transparent 36%),
    var(--color-bg);
  color: var(--color-text);
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-shell {
  padding: 108rpx var(--page-padding) 40rpx;
  box-sizing: border-box;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1.2;
}

.page-subtitle {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.soft-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: var(--card-radius);
  box-shadow: var(--shadow-soft);
  backdrop-filter: blur(12rpx);
}

.section-spacer {
  margin-top: 24rpx;
}

.pill-button {
  height: 84rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #45d5b0, var(--color-primary));
  color: #ffffff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.ghost-button {
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: var(--color-primary-soft);
  color: var(--color-primary);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
